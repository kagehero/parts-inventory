# PostgreSQL connection string (e.g. Neon, Supabase, local Docker)
DATABASE_URL="postgresql://user:password@localhost:5432/parts_inventory?schema=public"

# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-change-me"

# Public URL used by NextAuth in production (e.g. https://parts.example.com)
AUTH_URL="http://localhost:3000"

# Optional: 自社名・住所・自社FAX（注文書印刷フッタに表示）
COMPANY_NAME="株式会社　下関"
COMPANY_ADDRESS="北海道虻田郡倶知安町八幡527"
COMPANY_FAX="0136-55-7529"

# Local directory for uploaded repair PDFs (created automatically)
UPLOAD_DIR="./storage/repairs"

# Vercel Blob (recommended on Vercel for repair PDFs + order attachments). Unset = local disk only.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Optional: send order-share emails via Resend (https://resend.com)
# RESEND_API_KEY="re_..."
# MAIL_FROM="Parts App <notify@yourdomain.com>"

# Optional comma-separated IPs for middleware restriction (unset = allow all when logged in)
# ALLOW_IPS="203.0.113.10,203.0.113.11"
